<!-- Precios Start -->
<div class="container-fluid py-5 wow fadeInUp" data-wow-delay="0.1s">
    <div class="container py-5">
        <div class=" text-center position-relative pb-3 mb-5 mx-auto" style="max-width: 600px;">
            <h5 class="fw-bold text-primary text-uppercase">{{ pricing.title }}</h5>
            <h1 class="mb-0">{{ pricing.subtitle }}</h1>
        </div>
        <div class="row g-0">
            {% for plan in pricing.plans %}
                {% include "components/pricingCard.njk" %}
            {% endfor %}
        </div>
    </div>
</div>
<!-- Precios End -->
