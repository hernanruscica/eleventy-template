<!-- Hero Start -->
<!-- Variables: heroImage, title, subtitle, ctaUrl, ctaText, breadcrumb, parentUrl, parentPage, currentPage -->

<div class="container-fluid bg-primary pt-4 pb-1 bg-header" 
    style="margin-bottom: 10px; background: linear-gradient(rgba(9, 30, 62, .7), rgba(9, 30, 62, .7)), url({{ site.baseUrl }}/assets/images/{{ heroImage or 'about.jpg' }}) center center no-repeat; background-size: cover;">
    {% if breadcrumb %}
    <div class="row py-5">
        <div class="col-12 pt-lg-5 mt-lg-5 text-center">
            <h1 class="display-4 text-white animated zoomIn">{{ title }}</h1>
            <a href="{{ parentUrl or '/' }}" class="h5 text-white">{{ parentPage or 'Home' }}</a>
            <i class="far fa-circle text-white px-2"></i>
            <a href="{{ currentUrl or '#' }}" class="h5 text-white">{{ currentPage or title }}</a>
        </div>
    </div>
    {% else %}
    <div class="row py-5">
        <div class="col-12 pt-lg-5 mt-lg-5 text-center">
            <h1 class="display-4 text-white animated zoomIn">{{ title }}</h1>
            {% if subtitle %}
            <p class="mb-4 text-white lh-lg">{{ subtitle }}</p>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>
<!-- Hero End -->
