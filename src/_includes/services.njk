<!-- Service Start -->
<div class="container-fluid pt-1 pb-2 wow fadeInUp" data-wow-delay="0.1s">
    <div class="container py-3">
        <div class=" text-center position-relative pb-3 mb-5 mx-auto" style="max-width: 600px;">
            <h1 class="mb-0">{{ services.title }}</h1>
            <h5 class="fw-bold text-primary text-uppercase">{{ services.description }}</h5>
        </div>
        <div class="row g-5">
            {% for service in services.list %}
            <div class="col-lg-4 col-md-6 wow zoomIn" data-wow-delay="0.3s">
                <div class="service-item bg-light rounded d-flex flex-column align-items-center justify-content-center text-center">
                    <div class="service-icon">
                        <i class="{{ service.icon }} text-dark"></i>
                    </div>
                    <h4 class="mb-3">{{ service.title }}</h4>
                    <p class="m-0">{{ service.description }}</p>
                    {% if service.url %}
                    <a class="btn btn-lg btn-primary rounded" href="{{ service.url }}">
                        <i class="bi bi-arrow-right"></i>
                    </a>
                    {% endif %}
                </div>
            </div>
            {% endfor %}            
        </div>
    </div>
</div>
<!-- Service End -->
