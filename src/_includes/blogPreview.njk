<!-- Blog Preview Start -->
<div class="container-fluid py-5 wow fadeInUp" data-wow-delay="0.1s">
    <div class="container py-5">
        <div class="section-title text-center position-relative pb-3 mb-5 mx-auto" style="max-width: 600px;">
            <h5 class="fw-bold text-primary text-uppercase">Blog</h5>
            <h1 class="mb-0">Últimos artículos de nuestro blog</h1>
        </div>
        <div class="row g-5">
            {% set previewPosts = [
                { image: site.baseUrl + "/assets/images/blog-1.jpg", category: "Web Design", author: "Admin", date: "Ene 2025", title: "¿Cuánto Cuesta una Página Web?", excerpt: "Guía completa de precios para desarrollo web en Argentina 2025.", url: "/blog/1" },
                { image: site.baseUrl + "/assets/images/blog-2.jpg", category: "Seguridad", author: "Admin", date: "Feb 2025", title: "Seguridad en WordPress", excerpt: "Protege tu sitio web de vulnerabilidades y ataques.", url: "/blog/2" },
                { image: site.baseUrl + "/assets/images/blog-3.jpg", category: "Desarrollo", author: "Admin", date: "Mar 2025", title: "Desarrollo Web Moderno", excerpt: "Las mejores prácticas para construir sitios web rápidos y seguros.", url: "#" }
            ] %}

            {% for post in previewPosts %}
            <div class="col-lg-4 wow slideInUp" data-wow-delay="{{ loop.index * 0.3 }}s">
                {% set cardImage = post.image %}
                {% set cardCategory = post.category %}
                {% set cardAuthor = post.author %}
                {% set cardDate = post.date %}
                {% set cardTitle = post.title %}
                {% set cardExcerpt = post.excerpt %}
                {% set cardUrl = post.url %}
                {% include "components/blogCard.njk" %}
            </div>
            {% endfor %}
        </div>
    </div>
</div>
<!-- Blog Preview End -->
