<!-- Footer Start -->
<div class="container-fluid bg-dark text-light mt-5 wow fadeInUp" data-wow-delay="0.1s">
    <div class="container">
        <div class="row gx-5">
            <div class="col-lg-4 col-md-6 footer-about">
                <div class="d-flex flex-column align-items-center justify-content-center text-center h-100 bg-primary p-4">
                    <a href="/" class="navbar-brand">
                        <img src="/assets/images/impulsalogo-pink.svg" alt="{{ site.name }}" style="max-width: 150px;">
                    </a>
                    <h1 class="m-0 text-white">{{ site.name }}</h1>
                    <p class="mt-3 mb-4">{{ site.description }}</p>
                </div>
            </div>
            <div class="col-lg-8 col-md-6">
                <div class="row gx-5">
                    <div class="col-lg-4 col-md-12 pt-5 mb-5">
                        <h3 class="text-light mb-0">Contacto</h3>
                        <div class="d-flex mb-2">
                            <i class="bi bi-geo-alt text-primary me-2"></i>
                            <p class="mb-0">Buenos Aires</p>
                        </div>
                        <div class="d-flex mb-2">
                            <i class="bi bi-envelope-open text-primary me-2"></i>
                            <a href="mailto:{{ site.client.email }}" class="mb-0 text-light">{{ site.client.email }}</a>
                        </div>
                        <div class="d-flex mb-2">
                            <i class="bi bi-telephone text-primary me-2"></i>
                            <a href="tel:{{ site.client.telephone }}" class="mb-0 text-light">{{ site.client.telephone }}</a>
                        </div>
                        <div class="d-flex mt-4">
                            {% for social in site.socials %}
                                <a class="btn btn-primary btn-square me-2" href="{{ social.url }}" aria-label="{{ social.text }}"><i class="fab fa-{{ social.icon }} fw-normal"></i></a>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-12 pt-0 pt-lg-5 mb-5">
                        <h3 class="text-light mb-0">Enlaces Rápidos</h3>
                        <div class="link-animated d-flex flex-column justify-content-start">
                            {% for section in site.sections %}
                                <a class="text-light mb-2" href="{{ section.url }}"><i class="bi bi-arrow-right text-primary me-2"></i>{{ section.name }}</a>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-12 pt-0 pt-lg-5 mb-5">
                        <h3 class="text-light mb-0">Nuestros Servicios</h3>
                        <div class="link-animated d-flex flex-column justify-content-start">
                            <a class="text-light mb-2" href="/servicios/desarrollo-sitios-web"><i class="bi bi-arrow-right text-primary me-2"></i>Desarrollo de Sitios Web</a>
                            <a class="text-light mb-2" href="/servicios/tiendas-online"><i class="bi bi-arrow-right text-primary me-2"></i>Tiendas Online</a>
                            <a class="text-light mb-2" href="/servicios/aplicaciones-personalizadas"><i class="bi bi-arrow-right text-primary me-2"></i>Aplicaciones Personalizadas</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container-fluid text-white" style="background: #061429;">
    <div class="container text-center">
        <div class="row justify-content-end">
            <div class="col-lg-8 col-md-6">
                <div class="d-flex align-items-center justify-content-center" style="height: 75px;">
                    <p class="mb-0">&copy; <a class="text-white border-bottom" href="{{ site.url }}">Impulsa Internet</a>. Todos los derechos reservados.</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Footer End -->
